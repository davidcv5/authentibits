---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage, rawSlug } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: 760px;
				padding-top: 4rem;
			}

			.article-header {
				margin-bottom: 2rem;
				border-bottom: 1px solid var(--color-border);
				padding-bottom: 2rem;
			}

			.back-link {
				display: inline-flex;
				margin-bottom: 2rem;
				color: var(--color-muted);
				font-size: 0.95rem;
				text-decoration: none;
			}

			.back-link:hover {
				color: var(--color-ink);
			}

			.date {
				margin-bottom: 0.85rem;
				color: var(--color-soft);
				font-size: 0.92rem;
			}

			.title h1 {
				margin-bottom: 1rem;
				font-size: 3rem;
				line-height: 1.08;
			}

			.description {
				max-width: 680px;
				margin: 0;
				color: var(--color-muted);
				font-size: 1.1rem;
				line-height: 1.55;
			}

			.last-updated-on {
				margin-top: 0.75rem;
				color: var(--color-soft);
				font-size: 0.92rem;
				font-style: italic;
			}

			.raw-link {
				display: inline-flex;
				margin: 1rem 0 0;
				color: var(--color-accent);
				font-size: 0.98rem;
				text-decoration: none;
			}

			.raw-link:hover {
				color: var(--color-ink);
			}

			.hero-image {
				margin-bottom: 2.5rem;
			}

			.hero-image img {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
			}

			.article-body {
				font-size: 1.08rem;
			}

			@media (max-width: 720px) {
				main {
					padding-top: 2.75rem;
				}

				.article-header {
					padding-bottom: 1.5rem;
				}

				.back-link {
					margin-bottom: 1.5rem;
				}

				.title h1 {
					font-size: 2.2rem;
				}

				.article-body {
					font-size: 1rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="article-header">
					<a href="/" class="back-link">Back to writing</a>
					<div class="title">
						<p class="date">
							<FormattedDate date={pubDate} />
						</p>
						<h1>{title}</h1>
						<p class="description">{description}</p>
						{
							updatedDate && (
								<p class="last-updated-on">
									Last updated <FormattedDate date={updatedDate} />
								</p>
							)
						}
						{
							rawSlug && (
								<a class="raw-link" href={`/raw/${rawSlug}`}>
									Read the raw notes
								</a>
							)
						}
					</div>
				</header>
				{
					heroImage && (
						<div class="hero-image">
							<Image
								width={1200}
								height={675}
								src={heroImage}
								alt=""
								loading="eager"
							/>
						</div>
					)
				}
				<div class="prose article-body">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
