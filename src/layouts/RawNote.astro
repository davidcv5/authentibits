---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"raw">["data"];

const { title, description, pubDate, updatedDate, sourceType } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} | Raw notes`} description={description} />
		<style>
			main {
				width: 760px;
				padding-top: 4rem;
			}

			.raw-header {
				margin-bottom: 2rem;
				border-bottom: 1px solid var(--color-border);
				padding-bottom: 2rem;
			}

			.back-link {
				display: inline-flex;
				margin-bottom: 2rem;
				color: var(--color-muted);
				font-size: 0.95rem;
				text-decoration: none;
			}

			.back-link:hover {
				color: var(--color-ink);
			}

			.kicker {
				margin-bottom: 0.75rem;
				color: var(--color-accent);
				font-size: 0.85rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			h1 {
				margin-bottom: 1rem;
				font-size: 3rem;
				line-height: 1.08;
			}

			.description {
				max-width: 680px;
				margin: 0;
				color: var(--color-muted);
				font-size: 1.08rem;
				line-height: 1.55;
			}

			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 1rem;
				margin: 1.25rem 0 0;
				color: var(--color-soft);
				font-size: 0.92rem;
			}

			.notice {
				margin: 0 0 2rem;
				border: 1px solid var(--color-border);
				border-radius: 4px;
				background: var(--color-surface);
				padding: 1rem;
				color: var(--color-muted);
				font-size: 0.98rem;
			}

			.raw-body {
				font-size: 1.04rem;
			}

			@media (max-width: 720px) {
				main {
					padding-top: 2.75rem;
				}

				h1 {
					font-size: 2.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<header class="raw-header">
					<a href="/" class="back-link">Back to writing</a>
					<p class="kicker">Raw notes</p>
					<h1>{title}</h1>
					<p class="description">{description}</p>
					<p class="meta">
						<span><FormattedDate date={pubDate} /></span>
						<span>Source: {sourceType}</span>
						{
							updatedDate && (
								<span>
									Updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</p>
				</header>
				<p class="notice">
					This is an intentionally unpolished source note. It is published for
					transparency so the edited post can be read against the original
					thinking.
				</p>
				<div class="prose raw-body">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
